"Su" = (
/obj/structure/table/reinforced,
/obj/item/paper/crumpled{
	info = "<center><logo><b>Glory to Nanotrasen</b> <br>2988-09-15, 06:17<i><center><station>Epsilion Eridani</center></i><h3>Tadeus Research Objectives</h3></center><hr>From: Rupert Reynolds, Nanotrasen Field Officer<hr>To The Tadeus Station Research Team,<br>You are hereby deployed to the Tadeus Research Station. Your primary mission is to rigorously analyze the biological and botanical samples provided to you. This fax grants you explicit authorization to conduct thorough examinations and execute experimental procedures of a dubious nature, within the confines of necessity. However, be advised: any findings or actions that jeopardize the interests of Nanotrasen will be met with swift and severe repercussions. Your adherence to this mission is vital and if we discover any sway in your alliegence, <i> you will be dealt with.</i><br><br><small><i>Good luck, <br></small></i><small><i>Rupert Reynolds, Nanotrasen Field Officer</i></small><hr><small><i>*This fax message and any accompanying documents are confidential and intended solely for the use of the individual or entity to whom they are addressed. If you are not the intended recipient, any disclosure, reproduction, distribution, or other use of this information is strictly prohibited.If you have received this message in error, please notify the sender immediately and permanently delete the original and any copies from your system.<br>Death to the Syndicate.<br>Glory to Nanotrasen.";
	name = "Tadeus Station Orders"
	},
/turf/simulated/floor/transparent/glass,
/area/shuttle/abandoned)
